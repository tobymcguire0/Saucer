# ──────────────────────────────────────────────
# Cookbook — Environment Variables Template
# ──────────────────────────────────────────────
# Copy this file to .env and replace the placeholder values:
#   cp .env.example .env
#
# .env is gitignored — your secrets stay local.
# NEVER commit real credentials.
# ──────────────────────────────────────────────

# ── RDS PostgreSQL ────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cookbook
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# ── AWS Credentials ──────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# ── S3 (Hero Image Storage) ─────────────────
S3_BUCKET_NAME=your-bucket-name

# ── Frontend (exposed to browser via Vite) ───
# Only VITE_* variables are visible in the browser bundle.
# Port must match the Express server (default: 3001).
VITE_API_URL=http://localhost:3001

# ── AWS Cognito (exposed to browser via Vite) ─
# Find these values in the AWS Cognito console under your User Pool.
# VITE_COGNITO_USER_POOL_ID — e.g. us-east-1_AbCdEfGhI
VITE_COGNITO_USER_POOL_ID=your-pool-id-here
# VITE_COGNITO_CLIENT_ID — the App Client ID (no secret)
VITE_COGNITO_CLIENT_ID=your-client-id-here
# VITE_COGNITO_REGION — AWS region where the pool lives
VITE_COGNITO_REGION=us-east-1
# VITE_COGNITO_DOMAIN — Cognito hosted-UI domain for sign-in/sign-out redirects
VITE_COGNITO_DOMAIN=https://your-domain-prefix.auth.us-east-1.amazoncognito.com

# ── AWS Cognito (server-side token verification) ─
# These are used by the Express server to verify Cognito-issued JWTs.
# They should match the User Pool and App Client used by the frontend.
COGNITO_USER_POOL_ID=your-pool-id-here
COGNITO_CLIENT_ID=your-client-id-here
