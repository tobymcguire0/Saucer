{
  "name": "saucer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "npm run build && wrangler dev",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome check . --linter-enabled=false --assist-enabled=false",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "server:check": "npm --prefix server run check",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test",
    "check:all": "npm run check && npm run server:check",
    "tauri": "tauri",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "idb": "^8.0.3",
    "oidc-client-ts": "^3.5.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-oidc-context": "^3.3.1",
    "tesseract.js": "^7.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "@cloudflare/vite-plugin": "^1.33.2",
    "@tailwindcss/vite": "^4.1.14",
    "@tauri-apps/cli": "^2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4",
    "wrangler": "^4.85.0"
  }
}
